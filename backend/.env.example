# Groq API key (get one at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional proxy if Groq returns 403 Forbidden from your server IP
# GROQ_HTTP_PROXY=http://proxy:3128
# GROQ_HTTP_PROXY=socks5://127.0.0.1:1080
GROQ_HTTP_PROXY=

# Database URL
DATABASE_URL=sqlite:///./izo_coach.db

# Secret for dev sessions (change in production)
SECRET_KEY=change-me-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Dev mode allows /api/dev-login without Telegram
DEV_MODE=true
