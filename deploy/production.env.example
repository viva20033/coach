# Production environment for trainer.izostudia.net
# Copy to /opt/izo-coach/backend/.env on the server

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# If Groq returns 403 from server (Cloudflare blocks datacenter IP), set a proxy:
# GROQ_HTTP_PROXY=http://proxy-host:3128
# GROQ_HTTP_PROXY=socks5://127.0.0.1:1080
GROQ_HTTP_PROXY=
DATABASE_URL=sqlite:////opt/izo-coach/backend/izo_coach.db
SECRET_KEY=CHANGE_ME_long_random_string
CORS_ORIGINS=https://trainer.izostudia.net
DEV_MODE=true
